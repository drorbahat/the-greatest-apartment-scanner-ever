#!/usr/bin/env bash
# Launch Chromium with Chrome DevTools Protocol (CDP) on the configured port.
# Auto-detects the chromium binary from common locations.
#
# Default behavior:
#   - If a graphical DISPLAY exists: open a visible Chromium window.
#   - If no DISPLAY exists: run headless.
#
# Override:
#   SCANNER_HEADLESS=1 ./scripts/scanner-chromium   # force headless
#   SCANNER_HEADLESS=0 ./scripts/scanner-chromium   # force visible window
#
# Usage: ./scripts/scanner-chromium [extra chromium flags...]
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
PROFILE="${SCANNER_BROWSER_PROFILE:-$ROOT/data/browser-profile}"
PORT="${SCANNER_BROWSER_PORT:-9223}"

# ── Find Chromium binary ──────────────────────────────────────────────────
CHROMIUM_BIN="${CHROMIUM_BIN:-}"
if [ -z "$CHROMIUM_BIN" ]; then
    for cand in \
        /usr/bin/chromium \
        /usr/bin/chromium-browser \
        /usr/bin/google-chrome \
        /usr/bin/google-chrome-stable \
        /snap/bin/chromium \
        /Applications/Google\ Chrome.app/Contents/MacOS/Google\ Chrome; do
        if [ -x "$cand" ]; then
            CHROMIUM_BIN="$cand"
            break
        fi
    done
fi

if [ -z "$CHROMIUM_BIN" ]; then
    echo "❌ Chromium not found. Set CHROMIUM_BIN=/path/to/chromium" >&2
    echo "   Install: apt install chromium-browser" >&2
    exit 1
fi

# ── Headless/visible mode ─────────────────────────────────────────────────
# If the machine has a desktop session, prefer visible mode so a human can solve
# Yad2/Facebook CAPTCHA in the actual scanner browser. On servers/containers,
# fall back to headless.
HEADLESS="${SCANNER_HEADLESS:-auto}"
if [ "$HEADLESS" = "auto" ]; then
    if [ -n "${DISPLAY:-}" ] || [ -n "${WAYLAND_DISPLAY:-}" ]; then
        HEADLESS="0"
    else
        HEADLESS="1"
    fi
fi

ARGS=(
    --no-first-run
    --lang=he-IL
    --disable-dev-shm-usage
    --password-store=basic
    --user-data-dir="$PROFILE"
    --remote-debugging-port="$PORT"
    --disable-gpu
    --disable-software-rasterizer
    --disable-features=IsolateOrigins,site-per-process
    --disable-site-isolation-trials
    --no-sandbox
)

if [ "$HEADLESS" = "1" ] || [ "$HEADLESS" = "true" ]; then
    echo "→ Chromium: $CHROMIUM_BIN (CDP port $PORT, headless)" >&2
    ARGS+=(--headless=new)
else
    echo "→ Chromium: $CHROMIUM_BIN (CDP port $PORT, visible window)" >&2
    # Open a blank page so the user immediately sees the scanner browser.
    ARGS+=(about:blank)
fi

mkdir -p "$PROFILE"
exec "$CHROMIUM_BIN" "${ARGS[@]}" "$@"
