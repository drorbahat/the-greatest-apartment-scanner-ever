# ═══════════════════════════════════════════════════════════════════════════
# Apartment Scanner — Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Required:
#   TELEGRAM_BOT_TOKEN — for Telegram bot (interactive commands + auto reports)
#                         Get from @BotFather on Telegram
#
# Optional (AI features):
#   GEMINI_API_KEY — Google Gemini API key for AI triage & normalization
#                    Without this, AI-powered listing enrichment is disabled.
#
# Optional (override defaults):
#   SCANNER_PROJECT_ROOT — project root path (auto-detected if not set)
#   SCANNER_BROWSER_PORT  — Chromium CDP port (default: 9223)
#   SCANNER_BROWSER_PROFILE — Chromium profile directory (default: data/browser-profile)
#
#   SCANNER_GEMINI_MODEL — Gemini model (default: gemini-3.1-flash-lite-preview)
#   SCANNER_LLM_MAX_RETRIES — max retries for LLM calls (default: 2)
#   SCANNER_LLM_RETRY_DELAY — delay between retries in seconds (default: 2)
#   SCANNER_LLM_CALL_DELAY  — rate limit delay between calls (default: 0.8)
#   SCANNER_LLM_CACHE — path to LLM extraction cache (default: artifacts/facebook/llm_extract_cache.json)
#
#   SCANNER_AI_NORMALIZER_ENABLED — enable AI normalization (0 or 1, default: 0)
#   SCANNER_AI_NORMALIZER_SHADOW — shadow mode: normalize but don't affect report (0 or 1, default: 1)
#   SCANNER_AI_NORMALIZER_MAX_ITEMS — max items per normalization run (default: 30)
#   SCANNER_AI_NORMALIZER_USE_LLM — use LLM in normalizer (0 or 1, default: 0)
#   SCANNER_AI_NORMALIZER_MAX_TEXT_CHARS — max chars for normalization input (default: 6000)
#   SCANNER_AI_NORMALIZER_CACHE — path to normalizer cache (default: artifacts/normalization/normalizer_cache.json)
#   SCANNER_AI_NORMALIZER_USE_IN_EVALUATOR — use normalized data in evaluator (0 or 1, default: 0)
#
# ═══════════════════════════════════════════════════════════════════════════

# ── Required ──────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here

# ── Optional: AI ──────────────────────────────────────────────────────────
# GEMINI_API_KEY=your_gemini_key_here

# ── Optional: Chromium ────────────────────────────────────────────────────
# SCANNER_BROWSER_PORT=9223
# SCANNER_BROWSER_PROFILE=data/browser-profile

# ── Optional: LLM ─────────────────────────────────────────────────────────
# SCANNER_GEMINI_MODEL=gemini-3.1-flash-lite-preview
# SCANNER_LLM_MAX_RETRIES=2
# SCANNER_LLM_RETRY_DELAY=2

# ── Optional: AI Normalizer ───────────────────────────────────────────────
# SCANNER_AI_NORMALIZER_ENABLED=0
# SCANNER_AI_NORMALIZER_SHADOW=1
